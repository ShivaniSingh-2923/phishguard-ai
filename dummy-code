INDIAN_SCAM_PREFIXES = ['700', '900']

@app.route('/check-number', methods=['POST'])
@limiter.limit("30 per minute")
def check_number():
    data = request.get_json()
    if not data or "number" not in data:
        return jsonify({"error": "No number provided"}), 400

    number = data.get('number', '').strip().replace(' ', '').replace('-', '')
    if not number:
        return jsonify({"error": "Number cannot be empty"}), 400

    logger.info(f"Phone check: {number[:6]}****")  # Log only first 6 digits for privacy
    stats["total_scans"] += 1

    # Normalize Indian number
    clean = number
    if clean.startswith('+91'): clean = clean[3:]
    if clean.startswith('0'):   clean = clean[1:]

    score = 0; reasons = []

    # 1. Known reported scam number
    if clean in KNOWN_SCAM_NUMBERS:
        stats["scams_detected"] += 1
        return jsonify({
            "status":  "SCAM", "score": 95,
            "reasons": [f"Community Reported: {KNOWN_SCAM_NUMBERS[clean]}",
                        "Flagged in PhishGuard Database"]
        })

    # 2. Valid Indian mobile (10 digits, starts with 6-9)
    if len(clean) != 10:
        score += 30; reasons.append("Invalid Length — Indian mobile must be 10 digits")
    elif clean[0] not in '6789':
        score += 40; reasons.append("Invalid Prefix — Indian mobiles start with 6,7,8,9")

    # 3. Repeating digit pattern (9999999999)
    if len(set(clean)) <= 3:
        score += 35; reasons.append("Suspicious Repeating Digit Pattern")

    # 4. Sequential pattern (1234567890)
    if clean in ['1234567890', '0987654321', '9876543210']:
        score += 35; reasons.append("Sequential Number — Likely Fake/Test Number")

    # 5. Known scam prefixes
    if any(clean.startswith(p) for p in INDIAN_SCAM_PREFIXES):
        score += 20; reasons.append(f"Known Spam Prefix ({clean[:3]}xxx)")

    final  = min(score, 100)
    status = "SCAM" if final >= 60 else ("WARNING" if final >= 30 else "SAFE")
    if status == "SCAM": stats["scams_detected"] += 1
    if not reasons: reasons = ["No community reports — Appears Clean"]
    return jsonify({"status": status, "score": final, "reasons": reasons})

