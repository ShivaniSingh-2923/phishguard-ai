# ─────────────────────────── UTILITIES ───────────────────────────────────────

def calculate_entropy(text):
    if not text: return 0
    probs = [text.count(c)/len(text) for c in set(text)]
    return -sum(p*math.log2(p) for p in probs)

def get_live_domain_age(domain):
    if not domain or '.' not in domain or domain.endswith('.local'): return 0
    try:
        w = whois.whois(domain)
        cd = w.creation_date
        if isinstance(cd, list): cd = cd[0]
        if cd and isinstance(cd, datetime):
            return (datetime.now() - cd.replace(tzinfo=None)).days
    except Exception: pass
    return 0

def check_typosquatting(domain_part):
    for legit, variants in TYPOSQUAT_TARGETS:
        if any(v in domain_part for v in variants):
            return True, legit
    return False, None

def check_abused_legitimate(url):
    for host in ABUSED_LEGIT_HOSTS:
        if host in url:
            path = url.split(host)[-1]
            path_hits = sum(1 for w in SUSPICIOUS_PATH_WORDS if w in path)
            return True, path_hits, host
    return False, 0, None

def check_evasion_patterns(url):
    return [(label, p) for p, label in EVASION_PATTERNS if re.search(p, url)]

def count_suspicious_domain_words(domain_name):
    return sum(1 for w in SUSPICIOUS_DOMAIN_WORDS if w in domain_name)

# ─────────────────────────── URL ANALYSIS ENGINE ─────────────────────────────


import re
import tldextract

def extract_features(url):
    url = url.lower()

    ext = tldextract.extract(url)
    domain = ext.domain

    features = {}

    # 1. dots
    features["dots"] = url.count('.')

    # 2. is_ip
    features["is_ip"] = 1 if re.match(r'^\d{1,3}(\.\d{1,3}){3}', url) else 0

    # 3. has_brand
    brands = [
        "google","facebook","amazon","microsoft","apple",
        "paypal","bank","instagram","netflix","sbi","hdfc","axis","paytm"
    ]
    features["has_brand"] = 1 if any(b in url for b in brands) else 0

    # 4. is_shortened
    shorteners = ["bit.ly","tinyurl.com","goo.gl","t.co","rebrand.ly"]
    features["is_shortened"] = 1 if any(s in url for s in shorteners) else 0

    # 5. url_length
    features["url_length"] = len(url)

    # 6. has_https
    features["has_https"] = 1 if url.startswith("https") else 0

    # 7. domain_length
    features["domain_length"] = len(domain)

    # 8. is_typosquat (basic heuristic)
    suspicious_patterns = ["g00gle","faceb00k","paypa1","micr0soft"]
    features["is_typosquat"] = 1 if any(p in url for p in suspicious_patterns) else 0

    return features

def analyze_url(url):
    try:
        # ── Input Cleaning ─────────────────────────────
        url = url.lower().strip()

        if not url:
            return {
                "status": "SAFE",
                "score": 0,
                "reasons": ["Empty URL"],
                "endee_match": None
            }

        # ── URL Validation ─────────────────────────────
        URL_REGEX = re.compile(
            r'^(https?:\/\/)?(([a-zA-Z0-9-]+\.)+[a-zA-Z]{2,})'
        )

        if not URL_REGEX.match(url):
            return {
                "status": "INVALID",
                "score": 0,
                "reasons": ["Invalid URL format"],
                "endee_match": None
            }

        # Add https if missing
        if not url.startswith(('http://', 'https://')):
            url = 'https://' + url

        # ── Extract Domain ─────────────────────────────
        ext = tldextract.extract(url)
        domain_name = ext.domain
        full_domain = f"{ext.domain}.{ext.suffix}"

        reasons = []
        risk_score = 0

        # ── 1. IP Domain ───────────────────────────────
        is_ip = 1 if re.match(r"^\d{1,3}(\.\d{1,3}){3}$", domain_name) else 0
        if is_ip:
            risk_score += 30
            reasons.append("IP Address as Domain")

        # ── 2. WHOIS Age (SAFE) ────────────────────────
        try:
            age = 0 if is_ip else get_live_domain_age(full_domain)
        except Exception:
            age = 0

        if age == 0:
            risk_score += 40
            reasons.append("Unverified/Private Domain Registration")
        elif age < 30:
            risk_score += 50
            reasons.append("Newly Registered Domain (<30 days)")

        # ── 3. Brand Impersonation ─────────────────────
        brands = ['paypal','google','sbi','hdfc','axis','netflix','amazon','apple','kyc','bank','yono','paytm','microsoft','instagram']
        official = ['paypal.com','google.com','sbi.co.in','hdfcbank.com','amazon.in','apple.com','paytm.com','microsoft.com','instagram.com']

        has_brand = any(b in url for b in brands)
        if has_brand and not any(o in full_domain for o in official):
            risk_score += 45
            reasons.append("High-Risk Brand Impersonation")

        # ── 4. TLD / Entropy / HTTPS ───────────────────
        if any(url.endswith(t) for t in ['.tk','.ml','.ga','.cf','.top','.xyz','.site','.online']):
            risk_score += 30
            reasons.append("Low-Trust TLD")

        entropy = calculate_entropy(domain_name)
        if entropy > 3.9:
            risk_score += 20
            reasons.append("Suspicious Random Character Pattern")

        if not url.startswith('https://'):
            risk_score += 15
            reasons.append("HTTP Only (No SSL)")

        # ── 5. Domain Length ───────────────────────────
        domain_length = len(domain_name)
        if domain_length > 25:
            risk_score += 30
            reasons.append(f"Very Long Domain ({domain_length} chars)")
        elif domain_length > 20:
            risk_score += 15
            reasons.append(f"Long Domain Name ({domain_length} chars)")

        # ── 6. Suspicious Words ────────────────────────
        word_hits = count_suspicious_domain_words(domain_name)
        if word_hits >= 3:
            risk_score += 25
            reasons.append(f"Multiple Suspicious Keywords ({word_hits})")
        elif word_hits == 2:
            risk_score += 12
            reasons.append(f"Suspicious Keyword Combo ({word_hits})")

        # ── 7. Single Segment Domain ───────────────────
        dots = url.count('.')
        if dots <= 1 and domain_length > 15:
            risk_score += 15
            reasons.append("Long Single-Segment Domain")

        # ── 8. Typosquatting ───────────────────────────
        is_typo, typo_target = check_typosquatting(full_domain)
        if is_typo:
            risk_score += 50
            reasons.append(f"Typosquatting: mimics {typo_target}")

        # ── 9. Abused Legit Platforms ──────────────────
        is_abused, path_hits, abused_host = check_abused_legitimate(url)
        if is_abused:
            risk_score += 50 + (path_hits * 15)
            reasons.append(f"Abused Trusted Platform ({abused_host})")

        # ── 10. Evasion Patterns ───────────────────────
        for label, _ in check_evasion_patterns(url):
            risk_score += 25
            reasons.append(f"Evasion: {label}")

        # ── 11. @ Trick ────────────────────────────────
        if '@' in url and '://' in url:
            risk_score += 40
            reasons.append("@ Symbol Trick")

        # ── 12. ML Model (SAFE) ────────────────────────
        shorteners = ['bit.ly','goo.gl','tinyurl','t.co','rebrand.ly']
        is_shortened = 1 if any(s in url for s in shorteners) else 0
        url_length = len(url)
        has_https = 1 if url.startswith('https://') else 0
        is_typosquat = 1 if is_typo else 0

        features = extract_features(url)

        input_df = pd.DataFrame([[
            features["dots"],
            is_ip,
            1 if has_brand else 0,
            is_shortened,
            features["url_length"],
            features["has_https"],
            features["domain_length"],
            1 if is_typo else 0,
        ]], columns=[
            "dots","is_ip","has_brand","is_shortened",
            "url_length","has_https","domain_length","is_typosquat"
        ])

        try:
            pred = model.predict(input_df)[0]
            prob = model.predict_proba(input_df)[0][1]   # probability of phishing
            confidence = round(prob * 100, 2)

            if pred == 1:
                risk_score += 25
                reasons.append(f"ML flagged suspicious pattern ({confidence}% confidence)")
                
        except Exception as e:
            logger.warning(f"ML error: {e}")
            confidence = 0

        # ── 13. Endee (SAFE) ───────────────────────────
        endee_result = None
        similar = []

        if ENDEE_AVAILABLE:
            try:
                similar = endee_semantic_search(url)
            except Exception:
                similar = []

        if similar:
            top = similar[0]
            sim = top.get("score", 0)
            label = top.get("payload", {}).get("label", "unknown")

            endee_result = {
            "similarity": round(sim * 100, 1),
            "matched_pattern": top.get("payload", {}).get("text", "")
            }

            if sim > 0.75 and label == "phishing":
                risk_score += 30
                reasons.append("Semantic phishing match")

        # ── 14. Numeric Domain ─────────────────────────
        if domain_name.isdigit():
            risk_score += 35
            reasons.append("Numeric-only domain")

        # ── 15. Safe Path Extraction ───────────────────
        try:
            full_url_path = url.split(full_domain, 1)[-1]
        except Exception:
            full_url_path = ""

        suspicious_ext = ['.php','.asp','.aspx','.exe','.apk']
        if any(ext in full_url_path for ext in suspicious_ext):
            risk_score += 20
            reasons.append("Suspicious file in URL")

        # ── 16. Query Params ───────────────────────────
        if '?' in url and any(p in url for p in ['token=', 'session=', 'uid=']):
            risk_score += 15
            reasons.append("Suspicious query params")

        # ── 17. Path Depth ─────────────────────────────
        if full_url_path.count('/') >= 3:
            risk_score += 20
            reasons.append("Deep path structure")

        final_score = min(risk_score, 100)
        status = "SCAM" if final_score >= 75 else ("WARNING" if final_score >= 40 else "SAFE")

        # ── Update stats ─────────────────────────────
        stats["total_scans"] += 1

        if status == "SCAM":
            stats["scams_detected"] += 1
        elif status == "WARNING":
            stats["warnings"] += 1

        # ── Save history ─────────────────────────────
        scan_entry = {
            "url": url,
            "status": status,
            "score": final_score,
            "time": datetime.now().strftime("%H:%M:%S")
        }

        history.insert(0, scan_entry)

        if len(history) > MAX_HISTORY:
            history.pop()

        # ── Return response ─────────────────────────────
        return {
            "status": status,
            "score": final_score,
            "confidence": confidence,
            "reasons": list(set(reasons)),
            "endee_match": endee_result,
            "details": {
                "age_days": age,
                "is_secure": url.startswith('https'),
                "entropy": round(entropy, 2),
                "domain_length": domain_length,
                "word_hits": word_hits,
                "is_typosquat": is_typo,
                "abused_host": abused_host
            }
        }

    except Exception as e:
        logger.error(f"Critical error in analyze_url: {str(e)}")
        return {
            "status": "ERROR",
            "score": 0,
            "reasons": ["Internal processing error"],
            "endee_match": None
        }

