    for vector_name, data in SMS_SCAM_VECTORS.items():
        if any(kw in text_lower for kw in data['keywords']):
            score += data['score']
            detections.append(data['label'])

    endee_result = None
    similar = endee_semantic_search(text)
    if similar:
        top = similar[0]; sim = top.get("score",0)
        if sim>0.75 and top.get("payload",{}).get("label")=="phishing":
            score+=20
            endee_result={"similarity":round(sim*100,1),"matched_pattern":top.get("payload",{}).get("text","")}
            detections.append(f"⚡ Endee: {round(sim*100)}% Semantic Match to Known Phishing")

    status = "SCAM" if score>=55 else ("WARNING" if score>=25 else "SAFE")
    if status=="SCAM": stats["scams_detected"]+=1
    return {"status":status,"score":min(score,100),"detections":detections,"endee_match":endee_result}

