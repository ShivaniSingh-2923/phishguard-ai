@app.route('/detect', methods=['GET', 'POST'])
@limiter.limit("20 per minute")   # Max 20 scans/min per IP — stops spam attacks
def detect():
    # ── Input Validation ──────────────────────────────────
    data = request.get_json()

    # Check: is JSON body present and has 'url' key?
    if not data or "url" not in data:
        logger.warning("Bad request: missing URL in body")
        return jsonify({"error": "No URL provided"}), 400

    # Check: clean the input — remove whitespace
    url = data.get("url", "").strip()

    # Check: is URL empty after cleaning?
    if not url:
        logger.warning("Bad request: empty URL received")
        return jsonify({"error": "URL cannot be empty"}), 400

    # Check: is URL suspiciously long? (normal URLs < 2048 chars)
    if len(url) > 2048:
        logger.warning(f"Bad request: URL too long ({len(url)} chars)")
        return jsonify({"error": "URL too long (max 2048 characters)"}), 400

    # Fix: add https:// if user forgot it
    if not re.match(r'https?://', url):
        url = 'https://' + url

    # ── Log the scan ──────────────────────────────────────
    logger.info(f"URL scan requested: {url[:80]}")

    stats["total_scans"] += 1

    if url.lower() in blacklist:
        logger.info(f"Blacklisted URL blocked: {url[:80]}")
        return jsonify({"status":"SCAM","score":100,"reasons":["Community Blacklisted"],"endee_match":None})

    result = analyze_url(url)
        # Save to MongoDB
    scans_collection.insert_one({
    "url": url,
    "result": result,
    "timestamp": datetime.now()
    })
    return jsonify(result)

